POSTGRES_USER=budget
POSTGRES_PASSWORD=budget
POSTGRES_DB=budgeting
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgres://budget:budget@db:5432/budgeting?sslmode=disable
JWT_SECRET=change-me-in-production
PORT=8080
MIGRATIONS_PATH=migrations

# Docker frontend build (port 80 → API on 8080). Leave unset when using `npm run dev` (Vite proxies /api).
VITE_API_URL=http://localhost:8080

# Optional in local dev. When unset, backend allows localhost/127.0.0.1 on any port.
# CORS_ORIGINS=https://budget.example.com,https://api.budget.example.com

# --- Production only (see .env.production.example and DEPLOY.md) ---
# APP_DOMAIN=budget.example.com
# API_DOMAIN=api.budget.example.com
# ACME_EMAIL=you@example.com
