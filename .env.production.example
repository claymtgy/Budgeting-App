# Copy to .env on your VPS before deploying:
#   cp .env.production.example .env

# --- Database (internal Docker network only) ---
POSTGRES_USER=budget
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_hex_24
POSTGRES_DB=budgeting
DATABASE_URL=postgres://budget:CHANGE_ME_use_openssl_rand_hex_24@db:5432/budgeting?sslmode=disable

# --- Auth ---
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# --- Public domains (DNS A records must point at your VPS) ---
APP_DOMAIN=budget.example.com
API_DOMAIN=api.budget.example.com

# Baked into the frontend at build time — must be HTTPS in production
VITE_API_URL=https://api.budget.example.com

# Comma-separated origins allowed by the backend CORS middleware
CORS_ORIGINS=https://budget.example.com

# Let's Encrypt account email (recommended for cert expiry notices)
ACME_EMAIL=you@example.com

# Docker network shared with your existing nginx container (see DEPLOY.md)
EDGE_NETWORK=edge
